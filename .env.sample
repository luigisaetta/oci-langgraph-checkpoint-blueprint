# Oracle Autonomous Database connection settings.
# Copy this file to .env and replace the placeholder values locally.
DB_USER=
DB_PWD=
WALLET_DIR=
WALLET_PWD=
DB_DSN=

# Example 02 FastAPI server settings.
# The Example 02 start script uses this port.
SERVER_PORT=8080

# Example 03 production-oriented FastAPI server and ADB pool settings.
# The pool values are local-demo defaults; size them for the target ADB service.
EXAMPLE03_SERVER_PORT=8081
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1

# Example 04 Next.js development UI origin allowed by Example 04 CORS.
# This is a browser origin, not an Oracle or API credential.
NEXTJS_UI_ORIGIN=http://127.0.0.1:3000

# Example 04 OCI Generative AI Responses API settings.
# GENAI_API_KEY is secret: set it only in the local .env file, never commit it.
# REGION builds the OpenAI-compatible OCI endpoint.
EXAMPLE04_SERVER_PORT=8082
GENAI_API_KEY=
REGION=eu-frankfurt-1
OCI_MODEL_ID=openai.gpt-5.5
